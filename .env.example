# ── App environment (apps/admin/.env and apps/student/.env) ──
# Expo reads EXPO_PUBLIC_* variables at build time.

EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
EXPO_PUBLIC_MAPBOX_TOKEN=pk.your-mapbox-public-token-here

# ── CI / Supabase CLI (GitHub Actions secrets, never committed) ──
# SUPABASE_ACCESS_TOKEN=sbp_...
# SUPABASE_SERVICE_ROLE_KEY=eyJ...
# STAGING_PROJECT_REF=your-staging-project-ref
# EAS_TOKEN=your-eas-token
