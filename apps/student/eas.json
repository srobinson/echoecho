{
  "cli": {
    "version": ">= 12.0.0",
    "appVersionSource": "remote"
  },
  "build": {
    "preview-student": {
      "distribution": "internal",
      "corepack": true,
      "env": {
        "APP_VARIANT": "student"
      },
      "android": {
        "buildType": "apk"
      }
    },
    "production-student": {
      "distribution": "store",
      "corepack": true,
      "env": {
        "APP_VARIANT": "student"
      }
    }
  }
}
